{
  "name": "storepilot",
  "version": "0.1.0",
  "private": true,
  "license": "MIT",
  "packageManager": "pnpm@11.14.0",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint --ignore-pattern next-env.d.ts .",
    "test": "vitest run",
    "prisma": "prisma",
    "db:local": "node -e \"require('fs').mkdirSync('.data',{recursive:true})\" && pglite-server --db=./.data/storepilot-pglite --port=5433 --host=127.0.0.1 --max-connections=10",
    "db:push": "prisma db push",
    "db:generate": "prisma generate",
    "db:seed": "prisma db push --skip-generate && prisma db seed"
  },
  "dependencies": {
    "@prisma/client": "6.19.3",
    "lucide-react": "latest",
    "next": "15.5.20",
    "openai": "6.48.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@electric-sql/pglite-socket": "^0.2.7",
    "@tailwindcss/postcss": "4.3.3",
    "@types/node": "latest",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "eslint": "8.57.1",
    "eslint-config-next": "15.5.20",
    "postcss": "latest",
    "prisma": "6.19.3",
    "tailwindcss": "4.3.3",
    "tsx": "^4.23.1",
    "typescript": "5.9.3",
    "vitest": "^4.1.10"
  }
}
